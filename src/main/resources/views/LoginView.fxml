<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">
    <children>
        <VBox alignment="CENTER" maxHeight="500.0" maxWidth="400.0" spacing="30.0"
              style="-fx-background-color: #1a1a2e; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 20, 0, 0, 0);">
            <padding>
                <Insets bottom="50.0" left="40.0" right="40.0" top="50.0" />
            </padding>

            <VBox alignment="CENTER" spacing="5.0">
                <Label text="KUMO APP" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="42.0" />
                    </font>
                    <style>-fx-effect: dropshadow(one-pass-box, #3d5afe, 5, 0, 0, 0);</style>
                </Label>
                <Label text="Tu biblioteca de juegos avanzada" textFill="#b4b4b4">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </VBox>

            <VBox spacing="20.0">
                <VBox spacing="8.0">
                    <Label text="CORREO ELECTRÓNICO" textFill="#3d5afe" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                    <TextField fx:id="txtEmail" promptText="ejemplo@kumo.com" prefHeight="45.0" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="CONTRASEÑA" textFill="#3d5afe" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                    <PasswordField fx:id="txtPassword" promptText="••••••••" prefHeight="45.0" />
                </VBox>
            </VBox>

            <Button fx:id="btnEntrar" defaultButton="true" maxWidth="Infinity" onAction="#handleLogin"
                    text="INICIAR SESIÓN" prefHeight="50.0" styleClass="button">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Button>

            <Hyperlink onAction="#abrirRegistro" text="¿No tienes cuenta? Regístrate aquí"
                       style="-fx-text-fill: #3d5afe; -fx-underline: false; -fx-font-size: 13px;" />
        </VBox>
    </children>
</StackPane>