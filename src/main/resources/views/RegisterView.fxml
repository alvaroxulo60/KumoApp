<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" styleClass="root" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegisterController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="NUEVO USUARIO" textFill="WHITE">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <GridPane hgap="15" vgap="15" alignment="CENTER">
        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" textFill="WHITE"/>
        <TextField fx:id="txtUsername" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="220" promptText="Tu nombre de usuario"/>

        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" textFill="WHITE"/>
        <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="correo@ejemplo.com"/>

        <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="2" textFill="WHITE"/>
        <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="(Opcional)"/>

        <Label text="Contraseña:" GridPane.columnIndex="0" GridPane.rowIndex="3" textFill="WHITE"/>
        <PasswordField fx:id="txtPassword" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="••••••••"/>
    </GridPane>

    <HBox spacing="20" alignment="CENTER">
        <Button text="CANCELAR" onAction="#handleCancelar" style="-fx-background-color: transparent; -fx-border-color: #ff4444; -fx-text-fill: #ff4444; -fx-border-radius: 20;"/>
        <Button text="CREAR CUENTA" onAction="#handleRegistrar" styleClass="button"/>
    </HBox>
</VBox>