<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GameFormController"
      style="-fx-background-color: #1e1e1e; -fx-padding: 30;">

    <Label text="AÑADIR VIDEOJUEGO" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label text="Título:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: white;"/>
        <TextField fx:id="txtTitulo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

        <Label text="Desarrollador:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: white;"/>
        <TextField fx:id="txtDesarrollador" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Año Lanzamiento:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: white;"/>
        <TextField fx:id="txtAnio" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Género:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: white;"/>
        <ComboBox fx:id="cbGenero" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="250" promptText="Seleccione..."/>

        <Label text="Plataforma:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: white;"/>
        <ComboBox fx:id="cbPlataforma" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="250" promptText="Seleccione..."/>
    </GridPane>

    <HBox spacing="20" alignment="CENTER">
        <Button text="CANCELAR" onAction="#handleCancelar"
                style="-fx-background-color: #ff4444; -fx-text-fill: white;"/>
        <Button text="GUARDAR JUEGO" onAction="#handleGuardar"
                style="-fx-background-color: #3d5afe; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>